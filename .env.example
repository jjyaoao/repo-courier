# GitHub API（GitHub Actions 中会自动提供）
GITHUB_TOKEN=

# GitHub Trending 与五个 RSS 专题共用；未配置时自动使用本地规则回退
REPO_LLM_API_KEY=
REPO_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
REPO_LLM_MODEL=

# 可选：临时覆盖 config.yaml 中的关注词，以英文逗号分隔
REPO_COURIER_INTERESTS=agent,llm,mcp,developer tools,automation,self-hosted

# Web Beta：公开实例只允许请求这些模型服务，多个地址用英文逗号分隔
REPO_COURIER_ALLOWED_AI_BASE_URLS=https://api.openai.com/v1/chat/completions
REPO_COURIER_WEB_CONCURRENCY=2

# 飞书群机器人
FEISHU_WEBHOOK=

# 企业微信群机器人
WECOM_WEBHOOK=

# Server酱：推送到个人微信
SERVERCHAN_SENDKEY=

# OneBot v11：推送到个人 QQ
ONEBOT_URL=http://127.0.0.1:3000
ONEBOT_TOKEN=
ONEBOT_USER_ID=
